# Copy this file to .env for local development and fill in real values.
# Never commit the actual .env file - it is already listed in .gitignore.

APP_NAME="Clinic Booking API"
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Async SQLAlchemy connection string (note the +asyncpg driver).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/clinic_booking
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

CORS_ALLOWED_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true

SLOT_DURATION_MINUTES=30
MIN_BOOKING_LEAD_MINUTES=60

LOG_LEVEL=INFO
LOG_JSON=false
